[mysqld]
# 基础配置
port = 3306                            # MySQL服务监听端口,默认3306
character-set-server = utf8mb4         # 服务器默认字符集,支持完整Unicode(包括emoji)
collation-server = utf8mb4_0900_ai_ci  # 默认排序规则,不区分大小写和重音,utf8mb4_0900为MySQL 8.0新算法
default-time-zone = +08:00             # 服务器默认时区,设置为东八区(北京时间)

# 连接配置
max_connections = 200                 # 最大并发连接数,根据应用需求调整,每个连接消耗内存
wait_timeout = 600                    # 非交互式连接超时时间(秒),连接空闲超过此值将被关闭
interactive_timeout = 600             # 交互式连接超时时间(秒),如mysql命令行工具
skip-name-resolve = ON                # 跳过DNS反向解析,加快连接速度,仅能通过IP授权

# 查询与日志
slow_query_log = 1                    # 启用慢查询日志记录,1-启用,0-禁用
long_query_time = 2                   # 慢查询阈值(秒),执行时间超过此值的SQL将被记录

[mysql]
default-character-set = utf8mb4       # MySQL命令行客户端默认字符集

[client]
default-character-set = utf8mb4       # 所有MySQL客户端默认字符集