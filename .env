# ============================================
# 环境变量配置文件
# 被 start.sh 和 docker-compose.yml 读取使用
# ============================================

# ------------------------------
# 服务端口配置
# ------------------------------
# Spring Boot 项目的 HTTP 监听端口
# 需要与 application.yml 中的 server.port 一致
PORT=9999

# ------------------------------
# JVM 运行参数
# ------------------------------
# JAVA_OPTS：传递给 Java 虚拟机的启动参数
#   -Xms512m：初始堆内存大小，JVM 启动时预分配
#   -Xmx1g：最大堆内存，JVM 可使用的上限
#   -XX:+UseG1GC：使用 G1 垃圾回收器（适合低延迟场景）
# 注意：容器内存限制应大于此值，因为还有元空间、线程栈、GC 开销
JAVA_OPTS=-Xms512m -Xmx1g -XX:+UseG1GC

# ------------------------------
# Docker 容器资源限制
# ------------------------------
# MEMORY：容器最大可用内存（含 JVM 堆 + 元空间 + 线程栈 + 容器本身开销）
# 建议：MEMORY >= JVM 最大堆内存（-Xmx）+ 200MB 缓冲
MEMORY=1g