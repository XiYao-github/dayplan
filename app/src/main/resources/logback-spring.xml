<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback 配置文件
  - 文件名必须是 logback-spring.xml，放置在 resources 目录
  - Spring Boot 自动加载此文件
  - 支持多环境配置：<springProfile name="dev">、<springProfile name="prod">
-->
<configuration>
    <!-- ==================== 1. 定义属性（变量） ==================== -->
    <!-- 定义日志存储根目录 -->
    <property name="LOG_HOME" value="./logs"/>
    <!-- 定义应用名称（用于生成日志文件名） -->
    <property name="APP_NAME" value="dayplan"/>

    <!-- ==================== 2. 定义 Appender（输出目的地） ==================== -->

    <!-- 2.1 控制台 Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                日志输出格式说明：
                %d{yyyy-MM-dd HH:mm:ss.SSS}  - 时间（精确到毫秒）
                [%thread]                      - 线程名
                [%X{traceId}]                  - 从 MDC 获取链路追踪 ID
                %-5level                       - 日志级别（左对齐，宽度5）
                %logger{36}                    - 日志记录器名（宽度36，超长截断）
                %msg                           - 日志消息
                %n                              - 换行
            -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId}] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 2.2 文件 Appender（按天滚动） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 日志文件路径 -->
        <file>${LOG_HOME}/${APP_NAME}.log</file>

        <!-- 滚动策略：按时间 + 按大小 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!--
                滚动文件名格式：
                - %d{yyyy-MM-dd}  按天生成
                - %i              序号（当单文件超过最大大小时，0,1,2...）
                例：dayplan-2026-05-26.0.log, dayplan-2026-05-26.1.log
            -->
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>

            <!-- 按大小和时间触发滚动 -->
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <!-- 单文件最大 100MB -->
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>

            <!-- 保留 30 天日志 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId}] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 2.3 Error 日志文件（只记录 ERROR 级别） -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-error.log</file>

        <!-- 过滤器：只接收 ERROR 级别 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>50MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId}] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 3. Logger 配置（控制日志级别和输出） ==================== -->

    <!--
        Logger 配置说明：
        - name: 包名或类名
        - level: 日志级别（TRACE < DEBUG < INFO < WARN < ERROR）
        - additivity="false": 是否向上传递给父 Logger（false=不传递，只在此处处理）
    -->

    <!-- log 模块日志：单独控制，不向上传递 -->
    <logger name="com.xiyao.log" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ==================== 4. Root Logger（根日志器） ==================== -->
    <!--
        root 与 logger 的关系：
        - root 是最顶层的 Logger，所有 Logger 都继承自它
        - 当 Logger additivity="true" 时，日志会向上传递给 root
        - 此处定义全局默认配置
    -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

    <!-- ==================== 5. Spring Profile 多环境支持（可选） ==================== -->
    <!--
        可通过 spring.profiles.active=dev/prod 切换不同配置
        <springProfile name="dev">
            <root level="DEBUG">
                <appender-ref ref="CONSOLE"/>
            </root>
        </springProfile>

        <springProfile name="prod">
            <root level="WARN">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="FILE"/>
                <appender-ref ref="ERROR_FILE"/>
            </root>
        </springProfile>
    -->
</configuration>